generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin

  @@map("user_role")
}

enum SubscriptionTier {
  free
  standard
  pro

  @@map("subscription_tier")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  incomplete

  @@map("subscription_status")
}

enum EventTier {
  free
  standard
  pro

  @@map("event_tier")
}

enum EventType {
  birthday
  wedding
  baby_shower
  dinner
  corporate
  other

  @@map("event_type")
}

enum PurchaseStatus {
  pending
  completed
  refunded
  failed

  @@map("purchase_status")
}

enum InvitationStatus {
  pending
  accepted
  declined

  @@map("invitation_status")
}

enum EventRole {
  owner
  co_organizer
  guest

  @@map("event_role")
}

enum SubEventRsvpStatus {
  pending
  accepted
  declined

  @@map("sub_event_rsvp_status")
}

enum DatePollVoteStatus {
  yes
  maybe
  no

  @@map("date_poll_vote_status")
}

enum SubEventType {
  generic
  ceremony
  dinner
  party
  activity

  @@map("sub_event_type")
}

enum MusicRequestStatus {
  pending
  approved
  rejected
  queued

  @@map("music_request_status")
}

model User {
  clerkId   String   @id @map("clerk_id")
  email     String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  role      UserRole @default(user)
  aiTone         String?  @map("ai_tone")
  aiToneCustom   String?  @map("ai_tone_custom")
  aiExtraContext String?  @map("ai_extra_context")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  subscription       Subscription?
  events             Event[]
  eventPurchases     EventPurchase[]
  eventInvitations   EventInvitation[]
  eventMembers       EventMember[]
  templates          EventTemplate[]
  spotifyConnections SpotifyConnection[]

  @@map("users")
}

model Subscription {
  id                   Int                @id @default(autoincrement())
  userClerkId          String             @unique @map("user_clerk_id")
  tier                 SubscriptionTier   @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @map("updated_at")

  user User @relation(fields: [userClerkId], references: [clerkId])

  @@map("subscriptions")
}

model Event {
  id           Int        @id @default(autoincrement())
  title        String
  description  String?
  eventType    EventType? @map("event_type")
  eventDate    DateTime?  @map("event_date")
  eventEndDate DateTime?  @map("event_end_date")
  location     String?
  locationLat  Float?     @map("location_lat")
  locationLon  Float?     @map("location_lon")
  isPrivate      Boolean    @default(true) @map("is_private")
  shareToken     String?    @unique @map("share_token")
  tier           EventTier  @default(free)
  features       Json       @default("{}")
  coverImageUrl  String?    @map("cover_image_url")
  coverImageKey  String?    @map("cover_image_key")
  ownerClerkId   String     @map("owner_clerk_id")
  aiTone         String?    @map("ai_tone")
  aiToneCustom   String?    @map("ai_tone_custom")
  aiExtraContext String?    @map("ai_extra_context")
  rsvpEnabled    Boolean    @default(true) @map("rsvp_enabled")
  rsvpDeadline   DateTime?  @map("rsvp_deadline")
  archivedAt     DateTime?  @map("archived_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @map("updated_at")

  owner              User               @relation(fields: [ownerClerkId], references: [clerkId])
  purchases          EventPurchase[]
  invitations        EventInvitation[]
  subEvents          SubEvent[]
  members            EventMember[]
  timelineItems      TimelineItem[]
  views              EventView[]
  datePoll           DatePoll?
  wishlistItems      WishlistItem[]
  spotifyConnection  SpotifyConnection?

  @@map("events")
}

model DatePoll {
  id        Int      @id @default(autoincrement())
  eventId   Int      @unique @map("event_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  event   Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  options DatePollOption[]

  @@map("date_polls")
}

model DatePollOption {
  id         Int       @id @default(autoincrement())
  datePollId Int       @map("date_poll_id")
  date       DateTime
  startTime  DateTime? @map("start_time")
  endTime    DateTime? @map("end_time")
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")

  datePoll DatePoll       @relation(fields: [datePollId], references: [id], onDelete: Cascade)
  votes    DatePollVote[]

  @@map("date_poll_options")
}

model DatePollVote {
  id               Int                @id @default(autoincrement())
  datePollOptionId Int                @map("date_poll_option_id")
  voterEmail       String             @map("voter_email")
  voterName        String?            @map("voter_name")
  status           DatePollVoteStatus @default(yes)
  token            String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @default(now()) @map("updated_at")

  option DatePollOption @relation(fields: [datePollOptionId], references: [id], onDelete: Cascade)

  @@unique([datePollOptionId, voterEmail])
  @@map("date_poll_votes")
}

model EventPurchase {
  id                      Int            @id @default(autoincrement())
  eventId                 Int            @map("event_id")
  buyerClerkId            String         @map("buyer_clerk_id")
  tier                    EventTier
  status                  PurchaseStatus @default(pending)
  stripeCheckoutSessionId String?        @map("stripe_checkout_session_id")
  amountCents             Int            @map("amount_cents")
  createdAt               DateTime       @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])
  buyer User  @relation(fields: [buyerClerkId], references: [clerkId])

  @@map("event_purchases")
}

model EventInvitation {
  id             Int              @id @default(autoincrement())
  eventId        Int              @map("event_id")
  inviteeEmail   String           @map("invitee_email")
  inviteeName    String?          @map("invitee_name")
  inviterClerkId String           @map("inviter_clerk_id")
  status         InvitationStatus @default(pending)
  plusOnes       Int              @default(0) @map("plus_ones")
  accessToken    String           @unique @map("access_token")
  invitedById    Int?             @map("invited_by_id")
  createdAt      DateTime         @default(now()) @map("created_at")

  event           Event                @relation(fields: [eventId], references: [id])
  inviter         User                 @relation(fields: [inviterClerkId], references: [clerkId])
  invitedBy       EventInvitation?     @relation("PlusOneLink", fields: [invitedById], references: [id], onDelete: SetNull)
  plusOneInvites  EventInvitation[]     @relation("PlusOneLink")
  subEventInvites InvitationSubEvent[]

  @@map("event_invitations")
}

model SubEvent {
  id            Int          @id @default(autoincrement())
  eventId       Int          @map("event_id")
  title         String
  description   String?
  type          SubEventType @default(generic)
  richContent   String?      @map("rich_content")
  coverImageUrl String?      @map("cover_image_url")
  coverImageKey String?      @map("cover_image_key")
  capacity      Int?
  dressCode     String?      @map("dress_code")
  typeConfig    Json         @default("{}") @map("type_config")
  startTime     DateTime?    @map("start_time")
  endTime       DateTime?    @map("end_time")
  location      String?
  locationLat   Float?       @map("location_lat")
  locationLon   Float?       @map("location_lon")
  sortOrder     Int          @default(0) @map("sort_order")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @default(now()) @map("updated_at")

  event            Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvps            SubEventRsvp[]
  invitedGuests    InvitationSubEvent[]
  dietaryResponses SubEventDietary[]
  plusOneRequests   SubEventPlusOne[]
  musicRequests    SubEventMusicRequest[]

  @@map("sub_events")
}

model SubEventDietary {
  id           Int      @id @default(autoincrement())
  subEventId   Int      @map("sub_event_id")
  guestEmail   String   @map("guest_email")
  guestName    String?  @map("guest_name")
  restrictions String
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  subEvent SubEvent @relation(fields: [subEventId], references: [id], onDelete: Cascade)

  @@unique([subEventId, guestEmail])
  @@map("sub_event_dietaries")
}

model SubEventPlusOne {
  id           Int                @id @default(autoincrement())
  subEventId   Int                @map("sub_event_id")
  guestEmail   String             @map("guest_email")
  plusOneName   String             @map("plus_one_name")
  status       SubEventRsvpStatus @default(pending)
  createdAt    DateTime           @default(now()) @map("created_at")

  subEvent SubEvent @relation(fields: [subEventId], references: [id], onDelete: Cascade)

  @@map("sub_event_plus_ones")
}

model SubEventMusicRequest {
  id             Int                @id @default(autoincrement())
  subEventId     Int                @map("sub_event_id")
  guestEmail     String             @map("guest_email")
  songTitle      String             @map("song_title")
  artist         String?
  votes          Int                @default(1)
  status         MusicRequestStatus @default(pending)
  spotifyTrackId String?            @map("spotify_track_id")
  spotifyUri     String?            @map("spotify_uri")
  albumArtUrl    String?            @map("album_art_url")
  previewUrl     String?            @map("preview_url")
  durationMs     Int?               @map("duration_ms")
  playlistId     Int?               @map("playlist_id")
  createdAt      DateTime           @default(now()) @map("created_at")

  subEvent SubEvent         @relation(fields: [subEventId], references: [id], onDelete: Cascade)
  playlist SpotifyPlaylist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  @@map("sub_event_music_requests")
}

model InvitationSubEvent {
  id           Int @id @default(autoincrement())
  invitationId Int @map("invitation_id")
  subEventId   Int @map("sub_event_id")
  plusOnes     Int @default(0) @map("plus_ones")

  invitation EventInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  subEvent   SubEvent        @relation(fields: [subEventId], references: [id], onDelete: Cascade)

  @@unique([invitationId, subEventId])
  @@map("invitation_sub_events")
}

model SubEventRsvp {
  id         Int               @id @default(autoincrement())
  subEventId Int               @map("sub_event_id")
  guestEmail String            @map("guest_email")
  status     SubEventRsvpStatus @default(pending)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @map("updated_at")

  subEvent SubEvent @relation(fields: [subEventId], references: [id], onDelete: Cascade)

  @@unique([subEventId, guestEmail])
  @@map("sub_event_rsvps")
}

model EventMember {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  userClerkId String    @map("user_clerk_id")
  role        EventRole @default(guest)
  invitedEmail String?  @map("invited_email")
  createdAt   DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userClerkId], references: [clerkId])

  @@unique([eventId, userClerkId])
  @@map("event_members")
}

model EventTemplate {
  id               Int        @id @default(autoincrement())
  name             String
  description      String?
  eventType        EventType? @map("event_type")
  settings         Json       @default("{}")
  subEventTemplates Json      @default("[]") @map("sub_event_templates")
  isSystem         Boolean    @default(false) @map("is_system")
  ownerClerkId     String?    @map("owner_clerk_id")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @default(now()) @map("updated_at")

  owner User? @relation(fields: [ownerClerkId], references: [clerkId])

  @@map("event_templates")
}

model TimelineItem {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  title       String
  description String?
  location    String?
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("timeline_items")
}

model EventView {
  id        Int      @id @default(autoincrement())
  eventId   Int      @map("event_id")
  viewerIp  String?  @map("viewer_ip")
  userAgent String?  @map("user_agent")
  clerkId   String?  @map("clerk_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_views")
}

model WishlistItem {
  id                Int      @id @default(autoincrement())
  eventId           Int      @map("event_id")
  title             String
  description       String?
  imageUrl          String?  @map("image_url")
  imageKey          String?  @map("image_key")
  externalUrl       String?  @map("external_url")
  externalProductId String?  @map("external_product_id")
  provider          String   @default("manual")
  priceCents        Int?     @map("price_cents")
  currency          String   @default("EUR")
  category          String?
  priority          Int      @default(0)
  sortOrder         Int      @default(0) @map("sort_order")
  isPoolable        Boolean  @default(false) @map("is_poolable")
  poolTargetCents   Int?     @map("pool_target_cents")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")

  event  Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  claims WishlistClaim[]

  @@map("wishlist_items")
}

model SpotifyConnection {
  id                 Int      @id @default(autoincrement())
  eventId            Int      @unique @map("event_id")
  userClerkId        String   @map("user_clerk_id")
  spotifyUserId      String   @map("spotify_user_id")
  spotifyDisplayName String?  @map("spotify_display_name")
  accessToken        String   @map("access_token")
  refreshToken       String   @map("refresh_token")
  tokenExpiresAt     DateTime @map("token_expires_at")
  playlistId         String?  @map("playlist_id")
  playlistUrl        String?  @map("playlist_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @map("updated_at")

  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userClerkId], references: [clerkId])
  playlists SpotifyPlaylist[]

  @@map("spotify_connections")
}

model SpotifyPlaylist {
  id                  Int      @id @default(autoincrement())
  spotifyConnectionId Int      @map("spotify_connection_id")
  spotifyPlaylistId   String   @map("spotify_playlist_id")
  spotifyPlaylistUrl  String   @map("spotify_playlist_url")
  name                String
  createdAt           DateTime @default(now()) @map("created_at")

  connection    SpotifyConnection      @relation(fields: [spotifyConnectionId], references: [id], onDelete: Cascade)
  musicRequests SubEventMusicRequest[]

  @@map("spotify_playlists")
}

model WishlistClaim {
  id             Int      @id @default(autoincrement())
  wishlistItemId Int      @map("wishlist_item_id")
  guestEmail     String   @map("guest_email")
  guestName      String?  @map("guest_name")
  amountCents    Int?     @map("amount_cents")
  message        String?
  status         String   @default("claimed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  wishlistItem WishlistItem @relation(fields: [wishlistItemId], references: [id], onDelete: Cascade)

  @@unique([wishlistItemId, guestEmail])
  @@map("wishlist_claims")
}
