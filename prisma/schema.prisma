generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin

  @@map("user_role")
}

enum SubscriptionTier {
  free
  standard
  pro

  @@map("subscription_tier")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  incomplete

  @@map("subscription_status")
}

enum EventTier {
  free
  standard
  pro

  @@map("event_tier")
}

enum EventType {
  birthday
  wedding
  baby_shower
  dinner
  corporate
  other

  @@map("event_type")
}

enum PurchaseStatus {
  pending
  completed
  refunded
  failed

  @@map("purchase_status")
}

enum InvitationStatus {
  pending
  accepted
  declined

  @@map("invitation_status")
}

enum EventRole {
  owner
  co_organizer
  guest

  @@map("event_role")
}

enum SubEventRsvpStatus {
  pending
  accepted
  declined

  @@map("sub_event_rsvp_status")
}

enum DatePollVoteStatus {
  yes
  maybe
  no

  @@map("date_poll_vote_status")
}

model User {
  clerkId   String   @id @map("clerk_id")
  email     String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  role      UserRole @default(user)
  aiTone         String?  @map("ai_tone")
  aiToneCustom   String?  @map("ai_tone_custom")
  aiExtraContext String?  @map("ai_extra_context")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  subscription     Subscription?
  events           Event[]
  eventPurchases   EventPurchase[]
  eventInvitations EventInvitation[]
  eventMembers     EventMember[]
  templates        EventTemplate[]

  @@map("users")
}

model Subscription {
  id                   Int                @id @default(autoincrement())
  userClerkId          String             @unique @map("user_clerk_id")
  tier                 SubscriptionTier   @default(free)
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @default(now()) @map("updated_at")

  user User @relation(fields: [userClerkId], references: [clerkId])

  @@map("subscriptions")
}

model Event {
  id           Int        @id @default(autoincrement())
  title        String
  description  String?
  eventType    EventType? @map("event_type")
  eventDate    DateTime?  @map("event_date")
  eventEndDate DateTime?  @map("event_end_date")
  location     String?
  maxGuests    Int?       @map("max_guests")
  isPrivate      Boolean    @default(true) @map("is_private")
  tier           EventTier  @default(free)
  features       Json       @default("{}")
  coverImageUrl  String?    @map("cover_image_url")
  coverImageKey  String?    @map("cover_image_key")
  ownerClerkId   String     @map("owner_clerk_id")
  aiTone         String?    @map("ai_tone")
  aiToneCustom   String?    @map("ai_tone_custom")
  aiExtraContext String?    @map("ai_extra_context")
  archivedAt     DateTime?  @map("archived_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @default(now()) @map("updated_at")

  owner         User              @relation(fields: [ownerClerkId], references: [clerkId])
  purchases     EventPurchase[]
  invitations   EventInvitation[]
  subEvents     SubEvent[]
  members       EventMember[]
  timelineItems TimelineItem[]
  views         EventView[]
  datePoll      DatePoll?

  @@map("events")
}

model DatePoll {
  id        Int      @id @default(autoincrement())
  eventId   Int      @unique @map("event_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  event   Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  options DatePollOption[]

  @@map("date_polls")
}

model DatePollOption {
  id         Int       @id @default(autoincrement())
  datePollId Int       @map("date_poll_id")
  date       DateTime
  startTime  DateTime? @map("start_time")
  endTime    DateTime? @map("end_time")
  sortOrder  Int       @default(0) @map("sort_order")
  createdAt  DateTime  @default(now()) @map("created_at")

  datePoll DatePoll       @relation(fields: [datePollId], references: [id], onDelete: Cascade)
  votes    DatePollVote[]

  @@map("date_poll_options")
}

model DatePollVote {
  id               Int                @id @default(autoincrement())
  datePollOptionId Int                @map("date_poll_option_id")
  voterEmail       String             @map("voter_email")
  voterName        String?            @map("voter_name")
  status           DatePollVoteStatus @default(yes)
  token            String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @default(now()) @map("updated_at")

  option DatePollOption @relation(fields: [datePollOptionId], references: [id], onDelete: Cascade)

  @@unique([datePollOptionId, voterEmail])
  @@map("date_poll_votes")
}

model EventPurchase {
  id                      Int            @id @default(autoincrement())
  eventId                 Int            @map("event_id")
  buyerClerkId            String         @map("buyer_clerk_id")
  tier                    EventTier
  status                  PurchaseStatus @default(pending)
  stripeCheckoutSessionId String?        @map("stripe_checkout_session_id")
  amountCents             Int            @map("amount_cents")
  createdAt               DateTime       @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id])
  buyer User  @relation(fields: [buyerClerkId], references: [clerkId])

  @@map("event_purchases")
}

model EventInvitation {
  id             Int              @id @default(autoincrement())
  eventId        Int              @map("event_id")
  inviteeEmail   String           @map("invitee_email")
  inviterClerkId String           @map("inviter_clerk_id")
  status         InvitationStatus @default(pending)
  createdAt      DateTime         @default(now()) @map("created_at")

  event   Event @relation(fields: [eventId], references: [id])
  inviter User  @relation(fields: [inviterClerkId], references: [clerkId])

  @@map("event_invitations")
}

model SubEvent {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  title       String
  description String?
  startTime   DateTime? @map("start_time")
  endTime     DateTime? @map("end_time")
  location    String?
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  event Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvps SubEventRsvp[]

  @@map("sub_events")
}

model SubEventRsvp {
  id         Int               @id @default(autoincrement())
  subEventId Int               @map("sub_event_id")
  guestEmail String            @map("guest_email")
  status     SubEventRsvpStatus @default(pending)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @map("updated_at")

  subEvent SubEvent @relation(fields: [subEventId], references: [id], onDelete: Cascade)

  @@unique([subEventId, guestEmail])
  @@map("sub_event_rsvps")
}

model EventMember {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  userClerkId String    @map("user_clerk_id")
  role        EventRole @default(guest)
  invitedEmail String?  @map("invited_email")
  createdAt   DateTime  @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userClerkId], references: [clerkId])

  @@unique([eventId, userClerkId])
  @@map("event_members")
}

model EventTemplate {
  id               Int        @id @default(autoincrement())
  name             String
  description      String?
  eventType        EventType? @map("event_type")
  settings         Json       @default("{}")
  subEventTemplates Json      @default("[]") @map("sub_event_templates")
  isSystem         Boolean    @default(false) @map("is_system")
  ownerClerkId     String?    @map("owner_clerk_id")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @default(now()) @map("updated_at")

  owner User? @relation(fields: [ownerClerkId], references: [clerkId])

  @@map("event_templates")
}

model TimelineItem {
  id          Int       @id @default(autoincrement())
  eventId     Int       @map("event_id")
  title       String
  description String?
  location    String?
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("timeline_items")
}

model EventView {
  id        Int      @id @default(autoincrement())
  eventId   Int      @map("event_id")
  viewerIp  String?  @map("viewer_ip")
  userAgent String?  @map("user_agent")
  clerkId   String?  @map("clerk_id")
  createdAt DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_views")
}
