    "@clerk/nuxt": "^2.0.4",
    "@formkit/auto-animate": "^0.9.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^1.15.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/sitemap": "^7.6.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tiptap/pm": "^3.20.3",
    "@tiptap/starter-kit": "^3.20.3",
    "@tiptap/vue-3": "^3.20.3",
