# Clerk authentication
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NUXT_CLERK_SECRET_KEY=sk_test_...

# Database
DATABASE_URL=postgresql://postgres@localhost:5432/fishionaire-events

# AWS S3 & CloudFront
AWS_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-central-1
AWS_CDN_URL=https://your-distribution.cloudfront.net

# AWS SES (email)
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_SES_FROM_NAME=Fishionaire Events

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STANDARD_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_EVENT_STANDARD_PRICE_ID=price_...
STRIPE_EVENT_PRO_PRICE_ID=price_...

# Spotify (music features)
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret

# App
APP_URL=http://localhost:3000
